# =====================================================================
# .env.example - 環境変数テンプレート
# =====================================================================
# このファイルを参考に、各環境用の設定ファイルを作成してください:
#   - 本番サーバー上 : /.env (FTP で配置)
#   - ローカル開発   : .env.local
#
# どちらも .gitignore 対象です（このテンプレートのみ git 管理）。
# =====================================================================

# --- アプリケーション ---
APP_ENV=production           # production | staging | local
SESSION_TIMEOUT_HOURS=8
SSL_VERIFY_PEER=true
CSP_MODE=legacy

# 監査ログ署名キー（32文字以上）
# 生成: php -r "echo bin2hex(random_bytes(32));"
AUDIT_LOG_SIGNING_KEY=

# --- 外部API: MoneyForward ---
MF_CLIENT_ID=
MF_CLIENT_SECRET=
MF_ACCESS_TOKEN=
MF_REFRESH_TOKEN=

# --- フロントエンド ---
FRONTEND_URL=

# --- メール送信 ---
# true で送信抑止（ログ記録のみ）
# 未指定なら APP_ENV != production の時に自動抑止
MAIL_DISABLED=false

# --- データベース ---
# DB_MODE: json / dual / db
DB_MODE=db
DB_HOST=localhost            # 本番: mysql2301.xserver.jp
DB_PORT=3306
DB_NAME=adyamato_gear
DB_USER=root                 # 本番: adyamato_gear
DB_PASS=                     # 本番: ********

# --- セーフティスイッチ（必要時のみ） ---
# UPSERT モードに不具合が起きた場合のフォールバック
# DB_SAVE_MODE=full_replace

# PJ管理台帳のデータソース切替（既定: mysql）
# mysql : MySQL projects テーブルから取得（推奨・新方式）
# json  : pj-ledger.json から取得（旧方式・緊急時のフォールバック）
# auto  : MySQL → 失敗時は json
# PJ_LEDGER_SOURCE=mysql
